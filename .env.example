# Database option 1: static PostgreSQL URL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/dreamdrive?schema=public"

# Database option 2: AWS RDS/Aurora IAM-only authentication
# Leave DATABASE_URL unset when using this mode.
DATABASE_AUTH_MODE=""
RDS_HOST=""
RDS_PORT="5432"
RDS_DATABASE="postgres"
RDS_USER=""
RDS_REGION=""

# Auth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-long-random-string"

# Admin bootstrap (used by seed)
ADMIN_EMAIL="admin@dreamdriveauto.com"
ADMIN_PASSWORD="changeme"

# Email (SMTP for lead notifications)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="leads@dreamdriveauto.com"
LEADS_NOTIFY_TO="sales@dreamdriveauto.com"

# Vehicle photo uploads (production: S3 bucket with public read via S3 or CloudFront)
UPLOADS_S3_BUCKET=""
UPLOADS_S3_REGION="us-east-1"
UPLOADS_S3_PREFIX="uploads"
UPLOADS_PUBLIC_BASE_URL=""

# Dealer info (used in feeds + footer)
DEALER_NAME="Dream Drive Auto"
DEALER_ID=""
DEALER_PHONE="+1 (555) 014-7300"
DEALER_ADDRESS="2200 Mercer St, Seattle, WA 98109"
DEALER_WEBSITE="https://dreamdriveauto.com"

# AutoTrader syndication (SFTP)
AUTOTRADER_SFTP_HOST=""
AUTOTRADER_SFTP_PORT="22"
AUTOTRADER_SFTP_USER=""
AUTOTRADER_SFTP_PASS=""
AUTOTRADER_SFTP_PATH="/inbound"
AUTOTRADER_DEALER_ID=""

# CarGurus syndication (SFTP)
CARGURUS_SFTP_HOST=""
CARGURUS_SFTP_PORT="22"
CARGURUS_SFTP_USER=""
CARGURUS_SFTP_PASS=""
CARGURUS_SFTP_PATH="/inbound"
CARGURUS_DEALER_ID=""

# Syndication schedule (cron). Default: every 6 hours.
SYNDICATION_CRON="0 */6 * * *"
